---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, AUTHOR_NAME, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`${AUTHOR_NAME} — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
    <style>
      .hero {
        padding: 3rem 0 2rem;
        border-bottom: 1px solid var(--border);
        margin-bottom: 2.5rem;
      }
      .hero h1 {
        font-size: 2.4rem;
        font-weight: 700;
        margin: 0 0 0.5rem;
        background: linear-gradient(120deg, var(--accent), var(--accent-3));
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }
      .hero .byline {
        color: var(--text);
        font-size: 1rem;
        font-weight: 600;
        margin: 0 0 0.75rem;
      }
      .hero .tagline {
        color: var(--text-muted);
        font-size: 1rem;
        margin: 0 0 1.25rem;
        line-height: 1.6;
      }
      .posts-heading {
        font-size: 1.125rem;
        font-weight: 600;
        margin: 0 0 1.25rem;
        color: var(--heading);
      }
      ul.post-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
      }
      ul.post-list li a {
        text-decoration: none;
        display: block;
        padding: 1rem 1.25rem;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 10px;
        transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
      }
      ul.post-list li a:hover {
        border-color: var(--accent);
        box-shadow: var(--shadow);
        transform: translateY(-2px);
      }
      ul.post-list .post-title {
        font-size: 1.05rem;
        font-weight: 600;
        color: var(--heading);
        margin: 0 0 0.25rem;
      }
      ul.post-list .post-date {
        font-size: 0.8rem;
        color: var(--accent-2);
        margin: 0 0 0.4rem;
      }
      ul.post-list .post-desc {
        font-size: 0.875rem;
        color: var(--text-muted);
        margin: 0;
        line-height: 1.5;
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <div class="hero">
        <h1>{SITE_TITLE}</h1>
        <p class="byline">{AUTHOR_NAME} · Principal Engineer</p>
        <p class="tagline">
          Solution Architect · SaMD specialist · Melbourne, VIC<br />
          Writing about engineering, regulated software, and building with AI agents.
        </p>
      </div>

      <p class="posts-heading">Writing</p>
      <ul class="post-list">
        {posts.map((post) => (
          <li>
            <a href={`/blog/${post.id}/`}>
              <p class="post-title">{post.data.title}</p>
              <p class="post-date"><FormattedDate date={post.data.pubDate} /></p>
              <p class="post-desc">{post.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    </main>
    <Footer />
  </body>
</html>